<configuration>

    <!-- ================================================== -->
    <!-- Console Appender -->
    <!-- ================================================== -->
    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">

        <encoder>
            <pattern>
                %d{yyyy-MM-dd HH:mm:ss.SSS}
                [%thread]
                %-5level
                %logger{36}
                - %msg%n
            </pattern>
        </encoder>

    </appender>

    <!-- ================================================== -->
    <!-- DEV PROFILE -->
    <!-- ================================================== -->
    <springProfile name="dev">

        <appender name="DEV_FILE"
                  class="ch.qos.logback.core.rolling.RollingFileAppender">

            <file>./grievance-service/logs/dev/application.log</file>

            <rollingPolicy
                    class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

                <fileNamePattern>
                    ./grievance-service/logs/dev/application-%d{yyyy-MM-dd}.log
                </fileNamePattern>

                <maxHistory>15</maxHistory>

            </rollingPolicy>

            <!-- ONLY WARN & ERROR -->
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>

            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            </encoder>

        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="DEV_FILE"/>
        </root>

    </springProfile>

    <!-- ================================================== -->
    <!-- PROD PROFILE -->
    <!-- ================================================== -->
    <springProfile name="prod">

        <appender name="PROD_FILE"
                  class="ch.qos.logback.core.rolling.RollingFileAppender">

            <file>./grievance-service/logs/prod/application.log</file>

            <rollingPolicy
                    class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

                <fileNamePattern>
                    ./grievance-service/logs/prod/application-%d{yyyy-MM-dd}.log
                </fileNamePattern>

                <maxHistory>30</maxHistory>

            </rollingPolicy>

            <!-- ONLY WARN & ERROR -->
            <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
                <level>WARN</level>
            </filter>

            <encoder>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
            </encoder>

        </appender>

        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="PROD_FILE"/>
        </root>

    </springProfile>

</configuration>